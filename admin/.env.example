# ============================================================
# Admin Panel — Environment Variables
# Salin file ini ke .env lalu sesuaikan nilainya
# ============================================================

# URL backend API
# - Development: kosongkan (Vite proxy otomatis forward /api → localhost:3001)
# - Production : https://api.sizuwano.com/api (wajib diset)
#
# Catatan: Saat development, pastikan vite.config.ts sudah set proxy:
#   proxy: { "/api": { target: "http://localhost:3001" } }
# Ini sudah dikonfigurasi di vite.config.ts — tidak perlu ubah apa-apa.
VITE_API_URL=
