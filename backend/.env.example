# Server
PORT=3001
NODE_ENV=development

# JWT - gunakan nilai random minimal 64 karakter
JWT_SECRET=GANTI_DENGAN_RANDOM_STRING_MINIMAL_64_KARAKTER_CONTOH_abc123xyz
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Database
DATABASE_PATH=./data/portfolio.db

# CORS - URL frontend portfolio dan admin panel
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Admin initial credentials (hanya untuk seed pertama kali)
ADMIN_EMAIL=admin@sizuwano.com
ADMIN_PASSWORD=GANTI_PASSWORD_KUAT_INI

# Rate limiting
RATE_LIMIT_AUTH=5
RATE_LIMIT_WINDOW=60000
